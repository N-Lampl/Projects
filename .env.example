# Copy to .env (git-ignored) and fill in. NEVER commit real keys.
# Used by the 03-ml-privacy and 04-llm-security tracks.

# One of these for the LLM-security track (API path is first-class):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default cheap models for red-teaming (keep cost low):
LLM_PROVIDER=anthropic          # anthropic | openai | ollama
LLM_MODEL=claude-haiku-4-5      # cheap/fast class for multi-turn attacks
OLLAMA_MODEL=llama3.2:3b        # zero-cost CPU fallback (requires local Ollama)

# Hard caps so multi-turn attacks (TAP/Crescendo) don't run away on cost:
MAX_TURNS=6
MAX_BRANCHES=3
