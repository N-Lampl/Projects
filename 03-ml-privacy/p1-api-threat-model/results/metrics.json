{
  "project": "p1-api-threat-model",
  "summary": "Hardened model-serving endpoint: 12/12 abuse cases blocked by API-key auth, token-bucket rate limiting, strict input validation, and audit logging.",
  "seed": 42,
  "transport_default": "stdlib http.server (no fastapi required)",
  "transport_optional": "fastapi + uvicorn",
  "controls": {
    "api_key_auth": "salted SHA-256 hashes, constant-time compare",
    "rate_limit": "per-principal token bucket (capacity 5, 1 tok/s refill)",
    "input_validation": "type/shape/finiteness/range/batch-size checks -> 422",
    "audit_log": "in-memory ring buffer of auth/rate/predict events"
  },
  "abuse_tests": {
    "total": 12,
    "blocked_as_expected": 12,
    "cases": [
      {
        "case": "authorized valid request",
        "control": "baseline",
        "status": 200,
        "expected_status": 200,
        "passed": true
      },
      {
        "case": "missing API key",
        "control": "auth",
        "status": 401,
        "expected_status": 401,
        "passed": true
      },
      {
        "case": "wrong API key",
        "control": "auth",
        "status": 401,
        "expected_status": 401,
        "passed": true
      },
      {
        "case": "instances not a list",
        "control": "input-validation",
        "status": 422,
        "expected_status": 422,
        "passed": true
      },
      {
        "case": "wrong feature count",
        "control": "input-validation",
        "status": 422,
        "expected_status": 422,
        "passed": true
      },
      {
        "case": "non-numeric feature",
        "control": "input-validation",
        "status": 422,
        "expected_status": 422,
        "passed": true
      },
      {
        "case": "non-finite (NaN) feature",
        "control": "input-validation",
        "status": 422,
        "expected_status": 422,
        "passed": true
      },
      {
        "case": "oversized batch (DoS)",
        "control": "input-validation",
        "status": 422,
        "expected_status": 422,
        "passed": true
      },
      {
        "case": "missing 'instances' field",
        "control": "input-validation",
        "status": 422,
        "expected_status": 422,
        "passed": true
      },
      {
        "case": "burst of 10 requests, capacity 5",
        "control": "rate-limit",
        "status": "5 allowed / 5 throttled",
        "expected_status": "5 allowed / 5 throttled",
        "passed": true
      },
      {
        "case": "after 3s refill, 3 more requests",
        "control": "rate-limit",
        "status": "3 allowed",
        "expected_status": "3 allowed",
        "passed": true
      },
      {
        "case": "audit log recorded auth denials",
        "control": "audit",
        "status": "2 denied events",
        "expected_status": ">=2 denied events",
        "passed": true
      }
    ]
  },
  "audit": {
    "total_events": 3,
    "denied_events": 2,
    "error_events": 0
  },
  "figures": [
    "results/figures/rate_limit_bucket.png",
    "results/figures/controls_coverage.png"
  ]
}
