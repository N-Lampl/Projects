# Optional real LLM providers for the vulnerable-RAG lab target.
# The DEFAULT path needs NONE of this -- it runs offline with the mock provider.
# Authorized use only: use YOUR OWN keys / local Ollama. See ../../ETHICS.md.

# Select a provider: mock (default) | openai | anthropic | ollama
# RAG_PROVIDER=mock

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Ollama (local; no key)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
